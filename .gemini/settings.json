{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo GEMINI_HOOK_FIRED_$(date +%s) > /tmp/.react-template-init'",
            "name": "project-setup"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'echo BEFORE_TOOL_$(date +%s) >> /tmp/.react-template-init'",
            "name": "lint-runner"
          }
        ]
      }
    ]
  }
}
